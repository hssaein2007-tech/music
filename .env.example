# Required
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=123456:your_bot_token_here
ASSISTANT_SESSION=your_pyrogram_session_string_here
OWNER_ID=123456789

# Bot branding / links
CHANNEL_LINK=https://t.me/your_channel
SOURCE_LINK=https://t.me/your_source
BOT_IMAGE=https://your-image-link.example/image.jpg
NOW_PLAYING_TEMPLATE=https://i.postimg.cc/sD8Lg1Hs/IMG-2817.jpg
NOW_PLAYING_CHANNEL_NAME=@your_channel
NOW_PLAYING_SOURCE_NAME=@your_source

# Athan
ATHAN_TIMEZONE=Asia/Baghdad
ATHAN_LOCATION_LABEL=العراق/كربلاء
PRAYER_TIME_API_URL=https://hq.alkafeel.net/Api/init/init.php?timezone=Asia/Baghdad&long=44.0249&lati=32.6160&v=jsonPrayerTimes
ATHAN_FAJR_IMAGE=https://your-image-link.example/fajr.jpg
ATHAN_DHUHR_IMAGE=https://your-image-link.example/dhuhr.jpg
ATHAN_MAGHRIB_IMAGE=https://your-image-link.example/maghrib.jpg
ATHAN_CHECK_INTERVAL=20
ATHAN_PIN_SECONDS=3600
ATHAN_HTTP_TIMEOUT=20

# Persistence
DATA_DIR=/data
ATHAN_STATE_FILE=/data/athan_state.json
CHATS_DB_FILE=/data/chats_db.json

# yt-dlp (cookie-free mode)
YTDLP_PLAYER_CLIENT=default
YTDLP_CACHE_TTL=1800
YTDLP_RESOLVE_TIMEOUT=14
YTDLP_DOWNLOAD_TIMEOUT=180
YTDLP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36

# Runtime / healthcheck
HEALTHCHECK_HOST=0.0.0.0
HEALTHCHECK_PORT=8080
ASSISTANT_JOIN_TIMEOUT=12
ASSISTANT_MEMBER_CACHE_TTL=120
WATCHDOG_INTERVAL=45
TELEGRAM_PROBE_INTERVAL=180
TELEGRAM_PROBE_TIMEOUT=25
TELEGRAM_PROBE_FAILURE_LIMIT=3
UNHEALTHY_EXIT_AFTER=420
STREAM_URL_REFRESH_AFTER=14400
STATE_IDLE_TTL=43200
STUCK_TRACK_GRACE=45
